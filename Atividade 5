fun main(){
    var soma = 0.0
    var quantidade = 0
    print ("Digite o 1°valor: ")
    var valor1 = readln().toInt()
    print ("Digite o 2° valor: ")
    var valor2 = readln().toInt()
    for (i in valor1..valor2){
      soma += i
      quantidade += 1
    }
    var media = soma / quantidade
    println ("Média aritmética: $media ")

}
