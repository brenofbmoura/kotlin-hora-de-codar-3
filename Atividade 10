var dentro = 0
var fora = 0
var valor = 0
fun main(){
    for (i in 1..10){
        print ("Informe o $i° valor: ")
        valor = readLine()!!.toInt()
        if (valor >= 24 && valor <= 42){
            dentro++
        } else {
            fora++
        }
    }
    println ("Valores entre 24 e 42: $dentro")
    println ("Valores fora: $fora")
}
